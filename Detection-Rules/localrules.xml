<!-- RANSOMWARE DETECTION RULES                                   -->
<!-- ============================================================ -->
<group name="windows,ransomware,">

  <rule id="200050" level="15">
    <if_sid>200001</if_sid>
    <match>vssadmin.*delete|Delete Shadows</match>
    <description>RANSOMWARE DETECTED: Shadow Copy Deletion via VSSAdmin on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

  <rule id="200051" level="15">
    <if_sid>200001</if_sid>
    <match>wmic.*shadowcopy.*delete|ShadowCopy.*Delete</match>
    <description>RANSOMWARE DETECTED: Shadow Copy Deletion via WMIC on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

  <rule id="200052" level="15">
    <if_sid>200001</if_sid>
    <match>bcdedit.*recoveryenabled.*no|bcdedit.*bootstatuspolicy</match>
    <description>RANSOMWARE DETECTED: Boot Recovery Disabled on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

  <rule id="200053" level="15">
    <if_sid>200001</if_sid>
    <match>wbadmin.*delete.*catalog|wbadmin.*delete.*backup|wbadmin.*delete.*systemstate</match>
    <description>RANSOMWARE DETECTED: Windows Backup Deleted on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1490</id>
    </mitre>
  </rule>

  <rule id="200054" level="14">
    <if_sid>200001</if_sid>
    <match>DisableRealtimeMonitoring|Set-MpPreference.*Disable|DisableIOAVProtection|DisableBehaviorMonitoring</match>
    <description>RANSOMWARE PRE-STAGE: Windows Defender Disabled on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

  <rule id="200055" level="15">
    <if_sid>200001</if_sid>
    <match>wannacry|WannaCry|locky|petya|notpetya|ryuk|Ryuk|conti|Conti|revil|REvil|darkside|DarkSide|lockbit|LockBit|maze|Maze|sodinokibi|BlackCat</match>
    <description>CRITICAL: Known Ransomware Process Detected on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1486</id>
    </mitre>
  </rule>

  <rule id="200056" level="15">
    <if_sid>200010</if_sid>
    <match>\.locked|\.crypto|\.crypt|\.encrypted|\.wnry|\.wncry|\.ryuk|\.conti|\.locky|\.cerber|\.zepto</match>
    <description>CRITICAL: Ransomware File Extension Detected on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1486</id>
    </mitre>
  </rule>

  <rule id="200057" level="15">
    <if_sid>200010</if_sid>
    <match>HELP_DECRYPT|DECRYPT_INSTRUCTION|HOW_TO_RECOVER|YOUR_FILES_ARE_ENCRYPTED|HOW_TO_DECRYPT|RESTORE_FILES|RANSOM_NOTE</match>
    <description>CRITICAL: Ransom Note File Created on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1486</id>
    </mitre>
  </rule>

  <rule id="200058" level="12">
    <if_sid>200001</if_sid>
    <match>del.*\/f.*\/s|rd.*\/s.*\/q|cipher.*\/w</match>
    <description>SUSPICIOUS: Mass File Deletion Detected on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1485</id>
    </mitre>
  </rule>

  <rule id="200059" level="13">
    <if_sid>200001</if_sid>
    <match>taskkill.*MsMpEng|taskkill.*avguard|taskkill.*bdagent|taskkill.*ekrn|taskkill.*mcshield</match>
    <description>RANSOMWARE PRE-STAGE: Security Tool Process Killed on $(data.system_name)</description>
    <group>ransomware,</group>
    <mitre>
      <id>T1562.001</id>
    </mitre>
  </rule>

</group>

